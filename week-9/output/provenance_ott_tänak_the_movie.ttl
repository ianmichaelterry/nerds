    prov:startedAtTime "2026-03-04T16:36:56.336487"^^xsd:dateTime ;
    prov:wasAssociatedWith nerds:agent_HeroImageGen .

nerds:activity_IconFetcher_tick5_item_4 a prov:Activity ;
    prov:startedAtTime "2026-03-04T16:36:57.353731"^^xsd:dateTime ;
    prov:wasAssociatedWith nerds:agent_IconFetcher .

nerds:activity_LayoutPicker_tick1_item_0 a prov:Activity ;
    prov:startedAtTime "2026-03-04T16:36:46.256527"^^xsd:dateTime ;
    prov:wasAssociatedWith nerds:agent_LayoutPicker .

nerds:activity_MoviePicker_tick2_item_1 a prov:Activity ;
    prov:startedAtTime "2026-03-04T16:36:56.324015"^^xsd:dateTime ;
    prov:wasAssociatedWith nerds:agent_MoviePicker .

nerds:activity_TypefacePicker_tick6_item_5 a prov:Activity ;
    prov:startedAtTime "2026-03-04T16:36:57.363688"^^xsd:dateTime ;
    prov:wasAssociatedWith nerds:agent_TypefacePicker .


@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix nerds: <http://example.org/nerds/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

nerds:Blackboard a nerds:BlackboardSystem ;
    rdfs:label "NERDS Blackboard" ;
    nerds:contains nerds:item_0,
        nerds:item_1,
        nerds:item_2,
        nerds:item_3,
        nerds:item_4,
        nerds:item_5,
        nerds:item_6,
        nerds:item_7 .

nerds:PostEffect a skos:Concept ;
    rdfs:comment "Film grain, vignette, or posterization flags." ;
    skos:broader nerds:VisualArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Post Effect"@en .

nerds:TitleChunks a skos:Concept ;
    rdfs:comment "Primary and secondary title text segments." ;
    skos:broader nerds:TypographicArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Title Chunks"@en .

nerds:ColorPalette a skos:Concept ;
    rdfs:comment "Genre-derived key and accent colors." ;
    skos:broader nerds:VisualArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Color Palette"@en .

nerds:Completion a skos:Concept ;
    rdfs:comment "Signal that the poster is done." ;
    skos:broader nerds:MetaArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Completion"@en .

nerds:Critique a skos:Concept ;
    rdfs:comment "Completeness evaluation with issue list and score." ;
    skos:broader nerds:MetaArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Critique"@en .

nerds:FoundationalArtifact a skos:Concept ;
    rdfs:comment "Seed data that everything else derives from." ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Foundational Artifact"@en .

nerds:HeroImage a skos:Concept ;
    rdfs:comment "Procedural color-field imagery for the poster body." ;
    skos:broader nerds:VisualArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Hero Image"@en .

nerds:IconImage a skos:Concept ;
    rdfs:comment "Genre-relevant icon from the Noun Project, composited onto the poster." ;
    skos:broader nerds:VisualArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Icon Image"@en .

nerds:Layout a skos:Concept ;
    rdfs:comment "Poster layout template with y-positions and alignment." ;
    skos:broader nerds:StructuralArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Layout"@en .

nerds:MovieData a skos:Concept ;
    rdfs:comment "A film's metadata: title, director, cast, genre, year." ;
    skos:broader nerds:FoundationalArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Movie Data"@en .

nerds:StructuralArtifact a skos:Concept ;
    rdfs:comment "Layout and spatial organization." ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Structural Artifact"@en .

nerds:Typeface a skos:Concept ;
    rdfs:comment "Selected typeface name, style, and weight." ;
    skos:broader nerds:TypographicArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Typeface"@en .

nerds:activity_CompletionJudge_tick8_item_7 a prov:Activity ;
    prov:startedAtTime "2026-03-04T16:36:57.374124"^^xsd:dateTime ;
    prov:wasAssociatedWith nerds:agent_CompletionJudge .


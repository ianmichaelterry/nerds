nerds:IconImage a skos:Concept ;
    rdfs:comment "Genre-relevant icon from the Noun Project, composited onto the poster." ;
    skos:broader nerds:VisualArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Icon Image"@en .

nerds:MetaArtifact a skos:Concept ;
    rdfs:comment "Evaluation, critique, and completion signals." ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Meta Artifact"@en .

nerds:TitleChunks a skos:Concept ;
    rdfs:comment "Primary and secondary title text segments." ;
    skos:broader nerds:TypographicArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Title Chunks"@en .

nerds:TypographicArtifact a skos:Concept ;
    rdfs:comment "Title text and typeface selections." ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Typographic Artifact"@en .

nerds:agent_CompletionJudge a prov:SoftwareAgent ;
    rdfs:label "CompletionJudge" .

nerds:agent_HeroImageGen a prov:SoftwareAgent ;
    rdfs:label "HeroImageGen" .

nerds:agent_MoviePicker a prov:SoftwareAgent ;
    rdfs:label "MoviePicker" .

nerds:agent_TypefacePicker a prov:SoftwareAgent ;
    rdfs:label "TypefacePicker" .

nerds:ColorPalette a skos:Concept ;
    rdfs:comment "Genre-derived key and accent colors." ;
    skos:broader nerds:VisualArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Color Palette"@en .

nerds:Critique a skos:Concept ;
    rdfs:comment "Completeness evaluation with issue list and score." ;
    skos:broader nerds:MetaArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Critique"@en .

nerds:Layout a skos:Concept ;
    rdfs:comment "Poster layout template with y-positions and alignment." ;
    skos:broader nerds:StructuralArtifact ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Layout"@en .

nerds:VisualArtifact a skos:Concept ;
    rdfs:comment "Color, imagery, and post-processing data." ;
    skos:inScheme nerds:PosterArtifact ;
    skos:prefLabel "Visual Artifact"@en .

nerds:agent_IconFetcher a prov:SoftwareAgent ;
    rdfs:label "IconFetcher" .

nerds:agent_TitleParser a prov:SoftwareAgent ;
    rdfs:label "TitleParser" .

nerds:agent_Critic a prov:SoftwareAgent ;
    rdfs:label "Critic" .

nerds:agent_GenrePalette a prov:SoftwareAgent ;
    rdfs:label "GenrePalette" .

nerds:agent_LayoutPicker a prov:SoftwareAgent ;
    rdfs:label "LayoutPicker" .

nerds:PosterArtifact a skos:ConceptScheme ;
    rdfs:comment "Concept scheme for typed items on the NERDS blackboard." ;
    skos:prefLabel "Poster Artifact Types"@en .


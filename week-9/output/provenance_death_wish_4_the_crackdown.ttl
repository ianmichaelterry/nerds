nerds:agent_TitleParser a prov:SoftwareAgent ;
    rdfs:label "TitleParser" .

nerds:agent_TypefacePicker a prov:SoftwareAgent ;
    rdfs:label "TypefacePicker" .

nerds:PosterArtifact a skos:ConceptScheme ;
    rdfs:comment "Concept scheme for typed items on the NERDS blackboard." ;
    skos:prefLabel "Poster Artifact Types"@en .

